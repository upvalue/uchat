{
  "name": "uchat-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "codegen": "graphql-codegen",
    "codegen:watch": "graphql-codegen --watch",
    "deno:build": "graphql-codegen && deno run --allow-read --allow-write deno/build.ts",
    "build:prod": "UCHAT_BASE_PATH=/uchat/ tsc -b && UCHAT_BASE_PATH=/uchat/ vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.1",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.15",
    "@fontsource/iosevka": "^5.2.5",
    "@lezer/highlight": "^1.2.3",
    "@tanstack/react-query": "^5",
    "@tanstack/react-router": "^1",
    "ansi-to-pre": "^1.0.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "graphql": "^16",
    "graphql-request": "^7",
    "graphql-ws": "^5",
    "lucide-react": "^0.575.0",
    "radix-ui": "^1.4.3",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5",
    "@graphql-codegen/client-preset": "^4",
    "@graphql-codegen/typescript": "^5.0.8",
    "@graphql-codegen/typescript-operations": "^5.0.8",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@tailwindcss/vite": "^4.2.0",
    "@tanstack/router-plugin": "^1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite": "^6",
    "vitest": "^4.0.18"
  }
}
